# Root .env.example
#
# Mirrors apps/web/.env.example for convenience when running from the repo root.
# Per-app envs in apps/*/.env.example take precedence for that app.
#
# Copy to .env.local at the repo root if you want a single source for local dev.
# Never commit .env.local — it's gitignored.

# Supabase — leave empty at MVP. ADR 0003 explains why no production sync runs
# until Phase 2 (email-plus-VPC parental verification ships).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Environment marker — one of: development | preview | production
NEXT_PUBLIC_E4K_ENV=development
