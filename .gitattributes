# Git LFS tracking
#
# Large media + binary artifacts are stored in Git LFS so the working tree
# stays cheap to clone. Each pattern is paired with the rationale so future
# maintainers know whether to extend or replace it.

# Audio Pipeline (S4-2): opus/mp3 narration & SFX, ggml-format ML weights.
*.opus filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text

# STT Agent (S4-3): whisper.cpp tiny.en model + WASM runtime.
# These live under apps/web/public/whisper/ and are lazy-loaded only when
# the parent enables the offline speech engine — they are NOT in the PWA
# precache. The actual binaries land via the render-whisper-model workflow.
public/whisper/*.bin filter=lfs diff=lfs merge=lfs -text
public/whisper/*.wasm filter=lfs diff=lfs merge=lfs -text

# Piper voice models pulled by the render-narration workflow.
*.onnx filter=lfs diff=lfs merge=lfs -text
*.onnx.json filter=lfs diff=lfs merge=lfs -text

# Normalised line endings everywhere else.
* text=auto eol=lf
