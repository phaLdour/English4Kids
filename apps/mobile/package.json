{
  "name": "@e4k/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor wrapper that hosts the @e4k/web static export inside iOS and Android shells.",
  "scripts": {
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:build:web": "E4K_TARGET=mobile pnpm --filter @e4k/web build",
    "cap:ship": "pnpm cap:build:web && pnpm cap:copy"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor-community/microphone": "^7.0.0",
    "@capacitor-community/speech-recognition": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.6.3"
  }
}
