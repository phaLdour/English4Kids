NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_E4K_ENV=development
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
ALLOWED_ORIGIN=https://english4-kids.vercel.app

# Plausible analytics (parent-only) — set to enable.
# Cookieless, no PII, EU-hosted by default. Mounted exclusively from
# /parent/* via apps/web/src/app/parent/layout.tsx. Leave empty in any
# child-only deployment.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Email (Resend) — production. Set these as Supabase Edge Function secrets
# (NOT as Next.js env vars). They are read only by `supabase/functions/vpc-upgrade`.
# See docs/devops/email-setup.md for the DNS + Supabase CLI setup.
# RESEND_API_KEY=
# EMAIL_FROM=noreply@english4kids.app

# Email dev-mode (Edge Function secret, NOT a Next.js env var).
# When EMAIL_DEV_MODE=true the function:
#   - returns `devToken` in the /start response for copy-paste,
#   - allows ?devSkipDelay=1 on /confirm-second to bypass the 24h COPPA wait.
# Production deploys MUST leave this UNSET. See docs/devops/email-setup.md.
# EMAIL_DEV_MODE=false
