{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "allowJs": false,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@e4k/ui": ["../../packages/ui/src/index.ts"],
      "@e4k/ui/*": ["../../packages/ui/src/*"],
      "@e4k/audio": ["../../packages/audio/src/index.ts"],
      "@e4k/audio/*": ["../../packages/audio/src/*"],
      "@e4k/game-engine": ["../../packages/game-engine/src/index.ts"],
      "@e4k/game-engine/*": ["../../packages/game-engine/src/*"],
      "@e4k/content-schema": ["../../packages/content-schema/src/index.ts"],
      "@e4k/content-schema/*": ["../../packages/content-schema/src/*"],
      "@e4k/db": ["../../packages/db/src/index.ts"],
      "@e4k/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "next.config.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
