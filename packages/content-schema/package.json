{
  "name": "@e4k/content-schema",
  "version": "0.1.0",
  "description": "English4Kids content schemas (Zod) + banned-phrasing guard + validator CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./banned-words": {
      "types": "./dist/banned-words.d.ts",
      "import": "./dist/banned-words.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "bin": {
    "e4k-validate-content": "./dist/bin/validate-content.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:content": "tsx bin/validate-content.ts"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {},
  "sideEffects": false,
  "license": "MIT"
}
